		"main": [
			"yakshith.fruitcraft.Fruitcraft"
		],
		"client": [
			"yakshith.fruitcraft.client.FruitcraftClient"
		],
		"fabric-datagen": [
			"yakshith.fruitcraft.datagen.FruitcraftDataGenerator"
		]
	},
	"mixins": [
		"fruitcraft.mixins.json",
		{
			"config": "fruitcraft.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
