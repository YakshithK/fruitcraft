{
	"schemaVersion": 1,
	"id": "fruitcraft",
	"version": "${version}",
	"name": "Fruitcraft",
	"description": "Adds tropical fruit trees, crops, and food to Minecraft. Grow mangoes, cherries, grapes, lychees, and dragonfruits — each with unique effects.",
	"authors": [
		"Yakshith"
	],
	"license": "CC0-1.0",
	"icon": "assets/fruitcraft/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"yakshith.fruitcraft.Fruitcraft"
		],
		"client": [
			"yakshith.fruitcraft.client.FruitcraftClient"
		],
		"fabric-datagen": [
			"yakshith.fruitcraft.datagen.FruitcraftDataGenerator"
		]
	},
	"mixins": [
		"fruitcraft.mixins.json",
		{
			"config": "fruitcraft.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	}
}